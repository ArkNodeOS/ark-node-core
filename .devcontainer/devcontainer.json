{
	"name": "ark-node-core",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"remoteUser": "bun",
	"customizations": {
		"vscode": {
			"extensions": [
				"oven.bun-vscode",
				"EditorConfig.EditorConfig",
				"biomejs.biome"
			]
		}
	},
	"forwardPorts": [3000],
	"postCreateCommand": "bun install"
}
